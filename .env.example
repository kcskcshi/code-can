# Copy to .env and fill in to run in LIVE mode against your Supabase project.
# Leave unset (or omit the file) to run the self-contained DEMO simulation.

# Supabase project (Settings -> API)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Cloudflare Turnstile site key (optional bot protection).
# Get a key at https://dash.cloudflare.com/?to=/:account/turnstile
VITE_TURNSTILE_SITE_KEY=
